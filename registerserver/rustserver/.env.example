# QA register rustserver 本地配置示例。
#
# 本地运行时可以把本文件复制为同目录下的 `.env`，再按需修改配置值。
# 真实 `.env` 文件已被 git 忽略，不会提交到仓库。

# HTTP 和 WebSocket 监听端口。
PORT=3000

# HTTP 和 WebSocket 监听地址。
# 默认监听所有网卡，便于同一内网内的 Unity、Web 控制台和 qamcp 连接。
QA_LISTEN_HOST=0.0.0.0

# 访问范围。
# private: 默认值，只允许本机、RFC1918 私网、链路本地和 IPv6 内网来源。
# unrestricted: 不限制来源，只有在外部网关、防火墙或反向代理已做好保护时使用。
QA_ACCESS_SCOPE=private

# HTTP execute、WebSocket execute 和请求序列 step 的默认执行超时。
# 单位：毫秒。
EXECUTION_TIMEOUT_MS=20000

# 服务端 WebSocket ping/pong 检查间隔。
# 单位：毫秒。
WS_HEARTBEAT_INTERVAL_MS=15000

# 每个 WebSocket 连接的服务端出站队列长度。
# 队列满表示对端读取太慢，服务端会停止继续堆积消息，后续心跳会清理异常连接。
QA_WS_OUTBOUND_QUEUE_SIZE=1024

# Unity 业务 heartbeat 超过该时间未更新后，服务端会把 Unity 标记为不可用。
# 单位：毫秒。
UNITY_HEARTBEAT_STALE_MS=45000

# 可选的 Web 控制台登录 token。
# 留空表示 Web 控制台免登录；设置后浏览器打开控制台需要输入 token。
QA_WEB_CONSOLE_TOKEN=

# Web 控制台构建产物目录。
# 留空时优先使用 exe 同目录下的 client/dist；本地开发回退到仓库中的 ../client/dist。
# 线上 Windows 拷贝部署时，建议把 dist 放在 exe 同目录的 client/dist，或在此处写绝对路径。
QA_CLIENT_DIST_DIR=

# 截图/附件 artifact 存储目录。
# 留空时使用服务进程当前工作目录下的 artifacts 目录；目录不存在时会自动创建。
QA_ARTIFACT_DIR=

# 单个 artifact 最大上传字节数。默认 20MB，超出后返回 413 Payload Too Large。
QA_ARTIFACT_MAX_BYTES=20971520

# 可选的 JSONL 日志文件目录。
# 留空表示只输出到 stdout；设置后会同时写入按天切分的日志文件。
QA_LOG_DIR=logs

# 每日日志文件名前缀。文件名形如 `<prefix>.YYYY-MM-DD`。
QA_LOG_PREFIX=registerserver

# 是否启用 MariaDB/MySQL 执行历史存档。
# false: 默认关闭，不连接数据库。
# true: 启动时初始化连接池，并异步保存执行历史。
QA_EXECUTION_ARCHIVE_MYSQL_ENABLED=false

# MariaDB/MySQL 连接串。
# 示例：mysql://qa_register:qa_register_password@127.0.0.1:3306/qa_register_archive
QA_EXECUTION_ARCHIVE_MYSQL_URL=

# MariaDB/MySQL 连接池最大连接数。
QA_EXECUTION_ARCHIVE_MYSQL_MAX_CONNECTIONS=5

# 异步写入队列长度。队列满时丢弃存档任务并记录 warn 日志，不阻塞执行。
QA_EXECUTION_ARCHIVE_QUEUE_SIZE=10000
