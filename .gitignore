# QA Test Framework monorepo
#
# This repository tracks all project modules. Keep generated files,
# local configuration, dependencies, and Unity editor caches out of Git.

# Local build/runtime outputs
/output/
node_modules/
dist/
build/
release/
target/
coverage/
logs/
*.log
*.tgz
.env
.env.local
.env.*
!.env.example
!.env.*.example

# Tool caches and temporary files
.cache/
.vite/
.parcel-cache/
tmp/
temp/
*.tsbuildinfo

# Project-local runtime/config files
local_help.txt
qamcp.config.json
!qamcp.config.example.json
registerserver/rustserver/artifacts/

